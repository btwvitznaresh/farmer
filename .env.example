# ════════════════════════════════
#  AgroTalk Assist — Environment
#  Copy this to .env and fill in
# ════════════════════════════════

# ── OpenRouter AI (Required) ───
OPENROUTER_API_KEY=

# ── NVIDIA APIs (Optional, uses HF fallback if missing) ───
NVIDIA_VISION_KEY=
NVIDIA_TTS_KEY=
NVIDIA_TTS_FUNCTION_ID=
NVIDIA_STT_KEY=
NVIDIA_STT_FUNCTION_ID=

# ── Hugging Face (STT fallback) ───
HF_TOKEN=

# ── WhatsApp Bridge ───
WHATSAPP_LANGUAGE=en

# ── Firebase Admin (Required for session + Firestore) ───
# Paste the entire JSON from Firebase Console → Project Settings → Service Accounts
# Wrap the JSON in single quotes: FIREBASE_SERVICE_ACCOUNT='{ "type": "service_account", ... }'
FIREBASE_SERVICE_ACCOUNT=

# ── Frontend Firebase Config (same as src/.env) ───
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── Backend Port ───
PORT=3001
