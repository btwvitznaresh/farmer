# === AgroTalk Backend Environment Variables ===
# Copy this file to .env and fill in the values

# --- AI & API Keys ---
OPENROUTER_API_KEY=your_openrouter_api_key
NVIDIA_VISION_KEY=your_nvidia_vision_key
NVIDIA_TTS_KEY=your_nvidia_tts_key
NVIDIA_TTS_FUNCTION_ID=your_nvidia_tts_function_id
NVIDIA_STT_KEY=your_nvidia_stt_key

# --- Market API ---
MANDI_API_KEY=579b464db66ec23bdd000001fe9d36968d1d4e8e62fee0cc92cefecd
MANDI_API_BASE_URL=https://api.data.gov.in/resource/9ef84268-d588-465a-a308-a864a43d0070

# --- Firebase (JSON service account as a string) ---
FIREBASE_SERVICE_ACCOUNT=

# --- Frontend URL (for CORS) ---
FRONTEND_URL=https://your-frontend-url.web.app

# --- Server Port ---
PORT=3001
